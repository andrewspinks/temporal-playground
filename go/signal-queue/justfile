# Run the worker
worker:
    go run ./worker

# Run the API server
api:
    go run ./api

# Start a workflow execution (via curl)
start lz_id="lz-1" request_id="req-1":
    curl -s -X POST http://localhost:8090/request \
        -H "Content-Type: application/json" \
        -d '{"lz_id": "{{lz_id}}", "request_id": "{{request_id}}"}' | jq .

# Build all binaries
build:
    go build ./...

# Run tests
test:
    go test ./...

# Tidy dependencies
tidy:
    go mod tidy
